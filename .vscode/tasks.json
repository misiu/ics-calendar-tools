{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Test",
      "type": "shell",
      "command": "python",
      "args": [
        "-m",
        "pytest",
        "-q"
      ],
      "group": "test"
    },
    {
      "label": "Type check",
      "type": "shell",
      "command": "python",
      "args": [
        "-m",
        "mypy",
        "custom_components",
        "tests"
      ]
    },
    {
      "label": "Lint",
      "type": "shell",
      "command": "python",
      "args": [
        "-m",
        "ruff",
        "check",
        "custom_components",
        "tests"
      ]
    },
    {
      "label": "Format",
      "type": "shell",
      "command": "python",
      "args": [
        "-m",
        "ruff",
        "format",
        "custom_components",
        "tests"
      ]
    },
    {
      "label": "Pre-commit",
      "type": "shell",
      "command": "pre-commit",
      "args": [
        "run",
        "--all-files"
      ]
    },
    {
      "label": "Check all",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Test",
        "Type check",
        "Lint"
      ]
    }
  ]
}
