{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Tests: pytest",
      "type": "shell",
      "command": "pytest",
      "args": ["-q"],
      "group": "test"
    },
    {
      "label": "Types: mypy",
      "type": "shell",
      "command": "mypy",
      "args": ["custom_components", "tests"]
    },
    {
      "label": "Format: black",
      "type": "shell",
      "command": "black",
      "args": ["custom_components", "tests"]
    },
    {
      "label": "Imports: isort",
      "type": "shell",
      "command": "isort",
      "args": ["custom_components", "tests"]
    },
    {
      "label": "Check: black --check",
      "type": "shell",
      "command": "black",
      "args": ["--check", "custom_components", "tests"]
    },
    {
      "label": "Check: isort --check-only",
      "type": "shell",
      "command": "isort",
      "args": ["--check-only", "custom_components", "tests"]
    },
    {
      "label": "Check: all",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Tests: pytest",
        "Types: mypy",
        "Check: isort --check-only",
        "Check: black --check"
      ]
    }
  ]
}
